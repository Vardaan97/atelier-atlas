# Atelier Atlas — Environment Variables
# Copy this file to .env.local and fill in your API keys.
# The app works without any keys (degrades gracefully to static data).

# ─── AI Generation (OpenRouter) ───────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Image generation model (see src/lib/image-models.ts for all options)
# Options: nano-banana-2 (default), nano-banana-pro, gpt5-image, gpt5-image-mini,
#          seedream-4.5, riverflow-v2-fast, riverflow-v2-pro, grok-2-image, grok-imagine
IMAGE_GEN_MODEL=nano-banana-2

# ─── xAI / Grok (optional) ───────────────────────────────────────────
# Only needed if using grok-2-image or grok-imagine models
# Get your key at: https://console.x.ai/
# XAI_API_KEY=

# ─── Stock Image APIs (optional) ─────────────────────────────────────
# Without these, stock images won't load (AI images and static data still work)
# UNSPLASH_ACCESS_KEY=
# PEXELS_API_KEY=
